{
  "name": "odoo-qa",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright smoke tests for Odoo instances — fresh, migrated, or post-module-install",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep-invert 'perf:'",
    "test:perf": "playwright test --grep 'perf:'",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report test-results/report",
    "detect": "node scripts/detect-modules.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  }
}
